{
    "buildCommand": "npm run build && composer install --prefer-dist --no-dev",
    "functions": {
        "public/index.php": {
            "runtime": "now-php@1.0.0"
        }
    },
    "routes": [
        {
            "src": "/public/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ]
}